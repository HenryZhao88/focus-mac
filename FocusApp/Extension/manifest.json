{
  "manifest_version": 3,
  "name": "Focus Guard",
  "version": "1.0",
  "description": "Sends your current tab URL to the Focus app for monitoring.",
  "permissions": ["tabs", "activeTab", "windows", "storage"],
  "host_permissions": ["<all_urls>"],
  "background": {
    "service_worker": "background.js"
  },
  "action": {
    "default_popup": "popup.html",
    "default_title": "Focus Guard"
  }
}
